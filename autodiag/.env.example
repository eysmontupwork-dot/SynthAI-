# Gemini API key / Ключ Gemini API — get a free one at https://aistudio.google.com
GEMINI_API_KEY=your_key_from_aistudio.google.com

# Second Gemini key (used by the adapter researcher) — can be the same key
# Другий ключ Gemini (для дослідника адаптерів) — можна той самий
GEMINI_RESEARCH_API_KEY=second_key_or_the_same_one

# MAC address of your Bluetooth OBD adapter / MAC-адреса вашого OBD адаптера
OBD_MAC=AA:BB:CC:11:22:33
